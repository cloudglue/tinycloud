# Release parameters for scripts/generate-manifest.mjs.
# Copy to .env (gitignored) and fill in; real environment variables override.

# S3 bucket behind the distribution CDN
TINYCLOUD_S3_BUCKET=

# CloudFront distribution fronting the bucket (aws cloudfront list-distributions)
TINYCLOUD_CF_DISTRIBUTION_ID=

# Distribution base URL (rarely needs changing; also used by the installers)
# TINYCLOUD_DIST_URL=https://media.cloudglue.dev/tinycloud-dist
